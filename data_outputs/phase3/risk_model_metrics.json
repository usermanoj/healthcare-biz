{
  "task_name": "risk",
  "business_name": "Visit Risk Classification",
  "business_purpose": "Predict whether a hospital visit represents Low, Medium, or High operational/clinical risk to support triage, staffing, and resource planning.",
  "target": "risk_score",
  "labels": [
    "Low",
    "Medium",
    "High"
  ],

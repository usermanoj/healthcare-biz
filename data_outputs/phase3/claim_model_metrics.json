{
  "task_name": "claim",
  "business_name": "Claim Outcome Classification",
  "business_purpose": "Predict whether an insurance claim will be Paid, Pending, or Rejected before submission to support proactive revenue-risk control.",
  "target": "claim_status",
  "labels": [
    "Paid",
    "Pending",
    "Rejected"
  ],
